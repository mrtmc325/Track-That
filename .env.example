# =============================================================================
# Track-That Environment Variables (TEMPLATE — copy to .env and fill in values)
# NEVER commit .env to source control
# =============================================================================

# --- General ---
NODE_ENV=development
LOG_LEVEL=7

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trackhat
POSTGRES_USER=trackhat_admin
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# --- Per-service DB roles (least privilege) ---
AUTH_DB_USER=auth_svc
AUTH_DB_PASSWORD=CHANGE_ME_AUTH_DB_PASSWORD
CATALOG_DB_USER=catalog_svc
CATALOG_DB_PASSWORD=CHANGE_ME_CATALOG_DB_PASSWORD
COMMERCE_DB_USER=commerce_svc
COMMERCE_DB_PASSWORD=CHANGE_ME_COMMERCE_DB_PASSWORD
PROMOTIONS_DB_USER=promotions_svc
PROMOTIONS_DB_PASSWORD=CHANGE_ME_PROMOTIONS_DB_PASSWORD

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Elasticsearch ---
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# --- Auth Service ---
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
BCRYPT_COST_FACTOR=12

# --- Stripe ---
STRIPE_SECRET_KEY=CHANGE_ME_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=CHANGE_ME_STRIPE_WEBHOOK_SECRET
STRIPE_PUBLISHABLE_KEY=CHANGE_ME_STRIPE_PUBLISHABLE_KEY

# --- Delivery Providers ---
DOORDASH_API_KEY=CHANGE_ME_DOORDASH_API_KEY
DOORDASH_WEBHOOK_SECRET=CHANGE_ME_DOORDASH_WEBHOOK_SECRET
UBER_CLIENT_ID=CHANGE_ME_UBER_CLIENT_ID
UBER_CLIENT_SECRET=CHANGE_ME_UBER_CLIENT_SECRET
UBER_WEBHOOK_SECRET=CHANGE_ME_UBER_WEBHOOK_SECRET

# --- Scraping Proxy ---
# Set PROXY_ENABLED=true and PROXY_URL to route all scraping through a proxy
PROXY_ENABLED=false
PROXY_URL=
# Example: PROXY_URL=http://username:password@proxy-host:8080
# Supports HTTP/HTTPS/SOCKS5 proxy protocols

# --- Geo ---
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# --- Gateway ---
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=CHANGE_ME_TRAEFIK_PASSWORD
