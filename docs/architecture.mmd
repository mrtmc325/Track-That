    classDef datastore fill:#1b263b,stroke:#f72585,stroke-width:2px,color:#e0e0e0
    classDef external fill:#2b2d42,stroke:#fca311,stroke-width:1px,color:#e0e0e0
    classDef obs fill:#0d1b2a,stroke:#06d6a0,stroke-width:1px,color:#e0e0e0
    classDef edge fill:#16213e,stroke:#4895ef,stroke-width:2px,color:#e0e0e0

    class AUTH,SEARCH,VENDOR,ADS,PRICE,CART,DELIVERY,GEO service
